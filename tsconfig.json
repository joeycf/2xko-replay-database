{
  // Solution-style root (engine pattern, STACK.md §2): extends the canonical
  // baseline and delegates the APP typecheck to the Nuxt-4 project-references
  // contexts generated by `nuxt prepare`. `npm run typecheck` runs this via
  // `nuxt typecheck` (vue-tsc -b) AND the pipeline track via
  // `tsc -p tsconfig.pipeline.json` — two-track on purpose: the data pipeline
  // is plain node/tsx code that never enters the Nuxt graph.
  "extends": "./tsconfig.base.json",
  "files": [],
  "references": [
    { "path": "./.nuxt/tsconfig.app.json" },
    { "path": "./.nuxt/tsconfig.node.json" },
    { "path": "./.nuxt/tsconfig.shared.json" },
    { "path": "./.nuxt/tsconfig.server.json" }
  ]
}
